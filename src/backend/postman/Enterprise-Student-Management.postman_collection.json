              }
            },
            {
              "name": "Enroll Student",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"studentId\": 1,\n  \"notes\": \"Regular enrollment\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/classes/1/enroll",
                  "host": ["{{base_url}}"],
                  "path": ["api", "classes", "1", "enroll"]
                }
              }
            },
            {
              "name": "Get Class Enrollments",
              "request": {
                "method": "GET",
                "url": {
                  "raw": "{{base_url}}/api/classes/1/enrollments",
                  "host": ["{{base_url}}"],
